{
  "manifest_version": 3,
  "name": "My Personal Sticky Notes",
  "version": "1.0",
  "description": "Embeds sticky notes into websites.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}