{
  "manifest_version": 3,
  "name": "Sift",
  "version": "1.0",
  "description": "Annotate any website with beautiful, persistent sticky notes. Keep your research organized.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sift - View all annotated sites",
    "default_icon": "icon.svg"
  }
}